{
  "criteria_version": "1",
  "pillars": [
    {
      "id": "style-validation",
      "name": "Style & Validation",
      "criteria": [
        { "id": "formatter", "level": 1, "primitive": "file-exists",
          "params": { "path": ".editorconfig" },
          "title": "Formatter configured",
          "remediation": "Add .editorconfig + formatter (prettier/ruff/dotnet format/spotless/rubocop)" },
        { "id": "lint_config", "level": 1, "primitive": "file-exists",
          "params": { "path": ".eslintrc.json" },
          "title": "Linter configured",
          "remediation": "Add a linter (eslint/ruff/golangci/StyleCop/checkstyle/phpstan)" },
        { "id": "type_check", "level": 1, "primitive": "file-exists",
          "params": { "path": "tsconfig.json" },
          "title": "Type checking configured",
          "remediation": "Add tsconfig.json or mypy in pyproject.toml" },
        { "id": "strict_typing", "level": 2, "primitive": "content-regex",
          "params": { "path": "tsconfig.json", "regex": "\"strict\"\\s*:\\s*true" },
          "title": "Strict typing enabled",
          "remediation": "Enable strict typing (tsconfig strict, mypy strict, <Nullable>enable</Nullable>)" },
        { "id": "pre_commit_hooks", "level": 2, "primitive": "file-exists",
          "params": { "path": ".pre-commit-config.yaml" },
          "title": "Pre-commit hooks configured",
          "remediation": "Add .pre-commit-config.yaml or .husky/" },
        { "id": "naming_consistency", "level": 2, "primitive": "content-regex",
          "params": { "path": "AGENTS.md", "regex": "(?i)\\bnaming\\b|\\bconventions?\\b" },
          "title": "Naming conventions enforced",
          "remediation": "Document naming conventions in AGENTS.md or enforce via linter" },
        { "id": "large_file_detection", "level": 2, "primitive": "file-exists",
          "params": { "path": ".gitattributes" },
          "title": "Large file detection configured",
          "remediation": "Add .gitattributes with Git LFS" },
        { "id": "code_modularization", "level": 3, "primitive": "file-exists",
          "params": { "path": "nx.json" },
          "title": "Module boundaries enforced",
          "remediation": "Add import-linter, nx.json, or BUILD.bazel" },
        { "id": "cyclomatic_complexity", "level": 3, "primitive": "content-regex",
          "params": { "path": "pyproject.toml", "regex": "(?i)\\b(?:gocyclo|mccabe|radon)\\b|max[-_]?complexity|complexity\\s*[=:]" },
          "title": "Complexity analysis configured",
          "remediation": "Add complexity rules (mccabe/radon, CA1502, checkstyle, phpmetrics)" },
        { "id": "dead_code_detection", "level": 3, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "vulture|knip|deadcode" },
          "title": "Dead code detection enabled",
          "remediation": "Add vulture (Python) or knip (JS) to CI" },
        { "id": "duplicate_code_detection", "level": 3, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "jscpd|pmd cpd|sonarqube" },
          "title": "Duplicate detection enabled",
          "remediation": "Add jscpd or SonarQube to CI" },
        { "id": "tech_debt_tracking", "level": 4, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "todo|fixme|sonar" },
          "title": "Tech debt tracking enabled",
          "remediation": "Add TODO/FIXME scanning in CI" },
        { "id": "n_plus_one_detection", "level": 4, "primitive": "content-regex",
          "params": { "path": "package.json", "regex": "\\b(?:nplusone|bullet|query-analyzer|miniprofiler|hotchocolate)\\b" },
          "title": "N+1 detection enabled",
          "remediation": "Add nplusone (Python) or bullet (Ruby)" }
      ]
    },
    {
      "id": "build-system",
      "name": "Build System",
      "criteria": [
        { "id": "build_cmd_doc", "level": 1, "primitive": "content-regex",
          "params": { "path": "**/README*", "regex": "npm run|make\\s+(?:build|all|install|compile|dist|dev)\\b|cargo build|go build|gradle|mvn" },
          "title": "Build commands documented",
          "remediation": "Document build commands in README" },
        { "id": "deps_pinned", "level": 1, "primitive": "file-exists",
          "params": { "path": "package-lock.json" },
          "title": "Dependencies pinned with lockfile",
          "remediation": "Add a lockfile (package-lock.json/uv.lock/Cargo.lock/packages.lock.json)" },
        { "id": "vcs_cli_tools", "level": 1, "primitive": "file-exists",
          "params": { "path": ".gitignore" },
          "title": "VCS CLI assumed available (verify locally with: gh auth status)",
          "remediation": "VCS CLI assumed available (verify locally with: gh auth status)" },
        { "id": "fast_ci_feedback", "level": 2, "primitive": "file-exists",
          "params": { "path": ".github/workflows/*.{yml,yaml}" },
          "title": "CI workflow configured",
          "remediation": "Add a workflow under .github/workflows/ (.yml or .yaml)" },
        { "id": "single_command_setup", "level": 2, "primitive": "content-regex",
          "params": { "path": "**/README*", "regex": "make install|npm install|yarn install|pnpm install|docker-compose up" },
          "title": "Single command setup documented",
          "remediation": "Document single setup command in README" },
        { "id": "release_automation", "level": 2, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "release|publish|deploy" },
          "title": "Release automation configured",
          "remediation": "Add release workflow in .github/workflows/" },
        { "id": "deployment_frequency", "level": 2, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "release|publish|deploy" },
          "title": "Regular deployments",
          "remediation": "Set up CI/CD pipeline for automated deployments" },
        { "id": "release_notes_automation", "level": 3, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "changelog|release.notes|latest.changes" },
          "title": "Release notes automated",
          "remediation": "Add auto-changelog or release-please" },
        { "id": "agentic_development", "level": 3, "primitive": "content-regex",
          "params": { "path": "**/*.md", "regex": "(?i)co-authored-by|\\b(?:droid|copilot|claude|gpt|cursor|aider|anthropic)\\b" },
          "title": "AI agent commits detected",
          "remediation": "No AI agent commits found in recent history" },
        { "id": "automated_pr_review", "level": 3, "primitive": "file-exists",
          "params": { "path": "dangerfile.js" },
          "title": "Automated PR review configured",
          "remediation": "Add danger.js or PR lint workflow" },
        { "id": "feature_flag_infrastructure", "level": 3, "primitive": "content-regex",
          "params": { "path": "package.json", "regex": "launchdarkly|statsig|unleash|growthbook|openfeature|featurevisor" },
          "title": "Feature flags configured",
          "remediation": "Add LaunchDarkly, Statsig, or GrowthBook" },
        { "id": "build_performance_tracking", "level": 4, "primitive": "file-exists",
          "params": { "path": "turbo.json" },
          "title": "Build caching configured",
          "remediation": "Add turbo.json or nx.json" },
        { "id": "heavy_dependency_detection", "level": 4, "primitive": "content-regex",
          "params": { "path": "package.json", "regex": "webpack-bundle-analyzer|bundlesize|size-limit" },
          "title": "Bundle size tracking configured",
          "remediation": "Add webpack-bundle-analyzer or size-limit" },
        { "id": "unused_dependencies_detection", "level": 4, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "depcheck|deptry|go mod tidy" },
          "title": "Unused deps detection enabled",
          "remediation": "Add depcheck or deptry to CI" },
        { "id": "dead_feature_flag_detection", "level": 4, "primitive": "manifest-token",
          "params": { "manifest": "package.json", "token": "unsupported-signal-dead-feature-flag" },
          "title": "Manual check required: verify no unused feature flags exist",
          "remediation": "Manual check required: verify no unused feature flags exist" },
        { "id": "monorepo_tooling", "level": 4, "primitive": "file-exists",
          "params": { "path": "lerna.json" },
          "title": "Monorepo tooling configured",
          "remediation": "Add nx.json/turbo.json, multi-project .sln, or Maven <modules>" },
        { "id": "version_drift_detection", "level": 4, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "syncpack|manypkg|version.*check" },
          "title": "Version drift detection configured",
          "remediation": "Add syncpack/manypkg, Directory.Packages.props, or gradle libs.versions.toml" },
        { "id": "progressive_rollout", "level": 5, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "canary|gradual|rollout" },
          "title": "Progressive rollout configured",
          "remediation": "Add canary deployments" },
        { "id": "rollback_automation", "level": 5, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "rollback|revert|undo.*deploy|restore.*previous|failback" },
          "title": "Rollback automation configured",
          "remediation": "Add rollback/revert automation to CI" }
      ]
    },
    {
      "id": "testing",
      "name": "Testing",
      "criteria": [
        { "id": "unit_tests_exist", "level": 1, "primitive": "file-exists",
          "params": { "path": "tests/**/*.py" },
          "title": "Unit tests found",
          "remediation": "Add unit tests in tests/ directory" },
        { "id": "unit_tests_runnable", "level": 1, "primitive": "content-regex",
          "params": { "path": "**/README*", "regex": "pytest|npm test|go test|cargo test|make test" },
          "title": "Test commands documented",
          "remediation": "Document test command in README" },
        { "id": "test_naming_conventions", "level": 2, "primitive": "content-regex",
          "params": { "path": "pyproject.toml", "regex": "(?i)pytest" },
          "title": "Test naming conventions enforced",
          "remediation": "Use a test framework with naming conventions" },
        { "id": "test_isolation", "level": 2, "primitive": "content-regex",
          "params": { "path": "pyproject.toml", "regex": "pytest-xdist|-n auto" },
          "title": "Tests support isolation/parallelism",
          "remediation": "Enable parallel testing (pytest-xdist, xunit parallelism, junit-platform)" },
        { "id": "integration_tests_exist", "level": 3, "primitive": "file-exists",
          "params": { "path": "tests/integration/**" },
          "title": "Integration tests found",
          "remediation": "Add tests/integration/ or configure Playwright" },
        { "id": "test_coverage_thresholds", "level": 3, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "coverage|codecov|coveralls" },
          "title": "Coverage thresholds enforced",
          "remediation": "Add codecov.yml with minimum threshold" },
        { "id": "flaky_test_detection", "level": 4, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "retry|flaky|quarantine|rerun" },
          "title": "Flaky test handling configured",
          "remediation": "Add test retry logic in CI" },
        { "id": "test_performance_tracking", "level": 4, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "durations|timing|benchmark" },
          "title": "Test performance tracked",
          "remediation": "Add --durations flag to pytest" }
      ]
    },
    {
      "id": "documentation",
      "name": "Documentation",
      "criteria": [
        { "id": "readme", "level": 1, "primitive": "file-exists",
          "params": { "path": "**/README*" },
          "title": "README exists",
          "remediation": "Add README.md with project overview" },
        { "id": "agents_md", "level": 2, "primitive": "file-exists",
          "params": { "path": "AGENTS.md" },
          "title": "AI agent context file exists",
          "remediation": "Add AGENTS.md, CLAUDE.md, or .cursor/rules for AI coding assistants" },
        { "id": "documentation_freshness", "level": 2, "primitive": "file-exists",
          "params": { "path": "**/README*" },
          "title": "Documentation exists",
          "remediation": "Keep README.md up to date" },
        { "id": "api_schema_docs", "level": 3, "primitive": "file-exists",
          "params": { "path": "openapi.yaml" },
          "title": "API documentation exists",
          "remediation": "Add openapi.yaml or schema.graphql" },
        { "id": "automated_doc_generation", "level": 3, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "(?i)\\b(?:mkdocs|sphinx|typedoc|docusaurus|jsdoc|doxygen|pdoc)\\b|\\b(?:make|npm run|yarn|pnpm)\\s+docs\\b" },
          "title": "Doc generation automated",
          "remediation": "Add mkdocs or sphinx to CI" },
        { "id": "service_flow_documented", "level": 3, "primitive": "file-exists",
          "params": { "path": "docs/architecture*" },
          "title": "Architecture documented",
          "remediation": "Add docs/architecture.md with diagrams" },
        { "id": "skills", "level": 3, "primitive": "file-exists",
          "params": { "path": ".claude/skills/**" },
          "title": "Skills directory exists",
          "remediation": "Add .claude/skills/ for AI agent workflows" },
        { "id": "agents_md_validation", "level": 4, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "agents\\.md|claude\\.md" },
          "title": "AGENTS.md validation in CI",
          "remediation": "Add CI workflow to validate AGENTS.md" }
      ]
    },
    {
      "id": "dev-environment",
      "name": "Dev Environment",
      "criteria": [
        { "id": "env_template", "level": 2, "primitive": "file-exists",
          "params": { "path": ".env.example" },
          "title": "Environment template exists",
          "remediation": "Add .env.example or appsettings.Example.json" },
        { "id": "devcontainer", "level": 3, "primitive": "file-exists",
          "params": { "path": ".devcontainer/devcontainer.json" },
          "title": "Devcontainer configured",
          "remediation": "Add .devcontainer/devcontainer.json" },
        { "id": "devcontainer_runnable", "level": 3, "primitive": "content-regex",
          "params": { "path": ".devcontainer/devcontainer.json", "regex": "\"image\"\\s*:" },
          "title": "Devcontainer appears valid",
          "remediation": "Add 'image' to devcontainer.json" },
        { "id": "database_schema", "level": 3, "primitive": "file-exists",
          "params": { "path": "migrations/**" },
          "title": "Database schema managed",
          "remediation": "Add migrations/ or prisma/schema.prisma" },
        { "id": "local_services_setup", "level": 3, "primitive": "file-exists",
          "params": { "path": "docker-compose.yml" },
          "title": "Local services configured",
          "remediation": "Add docker-compose.yml" }
      ]
    },
    {
      "id": "observability",
      "name": "Debugging & Observability",
      "criteria": [
        { "id": "structured_logging", "level": 2, "primitive": "content-regex",
          "params": { "path": "package.json", "regex": "pino|winston|structlog|serilog" },
          "title": "Structured logging configured",
          "remediation": "Add pino (JS), structlog (Python), Serilog (.NET), logback (Java)" },
        { "id": "code_quality_metrics", "level": 2, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "coverage|sonar|quality" },
          "title": "Code quality metrics tracked",
          "remediation": "Add SonarQube or Codecov to CI" },
        { "id": "error_tracking_contextualized", "level": 3, "primitive": "content-regex",
          "params": { "path": "package.json", "regex": "sentry|bugsnag|rollbar|honeybadger" },
          "title": "Error tracking configured",
          "remediation": "Add Sentry, Bugsnag, or Rollbar" },
        { "id": "distributed_tracing", "level": 3, "primitive": "content-regex",
          "params": { "path": "package.json", "regex": "opentelemetry|jaeger|zipkin|datadog|x-request-id" },
          "title": "Distributed tracing configured",
          "remediation": "Add OpenTelemetry or Jaeger" },
        { "id": "metrics_collection", "level": 3, "primitive": "content-regex",
          "params": { "path": "package.json", "regex": "prometheus|datadog|newrelic|statsd|cloudwatch" },
          "title": "Metrics collection configured",
          "remediation": "Add Prometheus or Datadog" },
        { "id": "health_checks", "level": 3, "primitive": "content-regex",
          "params": { "path": "**/*.py", "regex": "(?i)[\"']/?(?:health|healthz|readyz|readiness|liveness|livez)\\b|def\\s+\\w*(?:health_?check|healthz|readiness|liveness)\\w*\\s*\\(" },
          "title": "Health checks implemented",
          "remediation": "Add /health, /ready endpoints" },
        { "id": "profiling_instrumentation", "level": 4, "primitive": "content-regex",
          "params": { "path": "requirements.txt", "regex": "pyinstrument|py-spy|pprof|clinic" },
          "title": "Profiling configured",
          "remediation": "Add pyinstrument (Python) or pprof (Go)" },
        { "id": "alerting_configured", "level": 4, "primitive": "file-exists",
          "params": { "path": "monitoring/**" },
          "title": "Alerting configured",
          "remediation": "Add monitoring/alerts.yml" },
        { "id": "deployment_observability", "level": 4, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "datadog|grafana|newrelic|deploy.*notify" },
          "title": "Deployment observability configured",
          "remediation": "Add deployment tracking" },
        { "id": "runbooks_documented", "level": 4, "primitive": "file-exists",
          "params": { "path": "runbooks/**" },
          "title": "Runbooks documented",
          "remediation": "Add runbooks/ with incident procedures" },
        { "id": "circuit_breakers", "level": 5, "primitive": "content-regex",
          "params": { "path": "package.json", "regex": "\\b(?:opossum|cockatiel|resilience4j|hystrix|polly|tenacity|circuitbox|gobreaker)\\b" },
          "title": "Circuit breakers configured",
          "remediation": "Add opossum (Node) or resilience4j" }
      ]
    },
    {
      "id": "security",
      "name": "Security",
      "criteria": [
        { "id": "gitignore_comprehensive", "level": 1, "primitive": "content-regex",
          "params": { "path": ".gitignore", "regex": "\\.env|node_modules|__pycache__" },
          "title": "Comprehensive .gitignore",
          "remediation": "Add language-appropriate ignores (.env, build outputs, IDE files)" },
        { "id": "secrets_management", "level": 2, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "secrets\\." },
          "title": "Secrets properly managed",
          "remediation": "Use GitHub Secrets in workflows" },
        { "id": "codeowners", "level": 2, "primitive": "file-exists",
          "params": { "path": "**/CODEOWNERS" },
          "title": "CODEOWNERS configured",
          "remediation": "Add .github/CODEOWNERS" },
        { "id": "branch_protection", "level": 2, "primitive": "file-exists",
          "params": { "path": ".github/branch-protection.yml" },
          "title": "Branch protection configured",
          "remediation": "Enable branch protection in GitHub" },
        { "id": "dependency_update_automation", "level": 3, "primitive": "file-exists",
          "params": { "path": ".github/dependabot.yml" },
          "title": "Dependency updates automated",
          "remediation": "Add .github/dependabot.yml" },
        { "id": "log_scrubbing", "level": 3, "primitive": "content-regex",
          "params": { "path": "package.json", "regex": "pino|redact|scrub" },
          "title": "Log scrubbing configured",
          "remediation": "Configure pino redact or loguru filters" },
        { "id": "pii_handling", "level": 3, "primitive": "content-regex",
          "params": { "path": "**/*.py", "regex": "(?i)\\b(?:redact|sanitiz|anonymi[sz]|scrub)\\w*\\s*\\(|\\bmask_\\w+\\s*\\(|\\bpii\\b" },
          "title": "PII handling implemented",
          "remediation": "Add redact/sanitize functions for PII" },
        { "id": "automated_security_review", "level": 4, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "codeql|snyk|sonar|security" },
          "title": "Security scanning enabled",
          "remediation": "Add CodeQL or Snyk to CI" },
        { "id": "secret_scanning", "level": 4, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "(?i)gitleaks|trufflehog|detect-secrets|secret[-_ ]?scan" },
          "title": "Secret scanning enabled",
          "remediation": "Add gitleaks to CI" },
        { "id": "dast_scanning", "level": 5, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "zap|dast|owasp|burp" },
          "title": "DAST scanning enabled",
          "remediation": "Add OWASP ZAP to CI" },
        { "id": "privacy_compliance", "level": 5, "primitive": "file-exists",
          "params": { "path": "PRIVACY.md" },
          "title": "Privacy compliance documented",
          "remediation": "Add PRIVACY.md" }
      ]
    },
    {
      "id": "task-discovery",
      "name": "Task Discovery",
      "criteria": [
        { "id": "issue_templates", "level": 2, "primitive": "file-exists",
          "params": { "path": ".github/ISSUE_TEMPLATE/**" },
          "title": "Issue templates configured",
          "remediation": "Add .github/ISSUE_TEMPLATE/" },
        { "id": "issue_labeling_system", "level": 2, "primitive": "content-regex",
          "params": { "path": ".github/ISSUE_TEMPLATE/*.md", "regex": "labels:" },
          "title": "Issue labels configured",
          "remediation": "Add 'labels:' to issue templates" },
        { "id": "pr_templates", "level": 2, "primitive": "file-exists",
          "params": { "path": ".github/pull_request_template.md" },
          "title": "PR template configured",
          "remediation": "Add .github/pull_request_template.md" },
        { "id": "backlog_health", "level": 3, "primitive": "file-exists",
          "params": { "path": "CONTRIBUTING.md" },
          "title": "Contributing guidelines exist",
          "remediation": "Add CONTRIBUTING.md" }
      ]
    },
    {
      "id": "product-analytics",
      "name": "Product & Analytics",
      "criteria": [
        { "id": "error_to_insight_pipeline", "level": 5, "primitive": "content-regex",
          "params": { "path": ".github/workflows/*.{yml,yaml}", "regex": "(?i)sentry|(?:create|open|file)[-_ ]?issues?\\b|issues?[-_ ]?create\\b" },
          "title": "Error-to-issue pipeline exists",
          "remediation": "Configure Sentry-GitHub integration" },
        { "id": "product_analytics_instrumentation", "level": 5, "primitive": "content-regex",
          "params": { "path": "package.json", "regex": "\\b(?:mixpanel|amplitude|posthog|heap|segment|ga4|google-analytics)\\b" },
          "title": "Product analytics configured",
          "remediation": "Add Mixpanel, Amplitude, or PostHog" }
      ]
    }
  ],
  "dimensions": [
    { "id": "oracle-coverage", "name": "Oracle Coverage", "kind": "fold",
      "criteria": ["unit_tests_exist", "unit_tests_runnable", "integration_tests_exist"] },
    { "id": "test-determinism", "name": "Test Determinism", "kind": "probe",
      "probe": "test-command-k-run" },
    { "id": "signal-quality", "name": "Signal Quality", "kind": "fold",
